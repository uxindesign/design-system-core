{
  "component": {
    "radio": {
      "$description": "Structural tokens for Radio component.",
      "control-size": {
        "sm": {
          "$type": "dimension",
          "$value": "{foundation.spacing.4}",
          "$description": "16px"
        },
        "md": {
          "$type": "dimension",
          "$value": "{foundation.spacing.5}",
          "$description": "20px"
        },
        "lg": {
          "$type": "dimension",
          "$value": "{foundation.spacing.6}",
          "$description": "24px"
        }
      },
      "dot-size": {
        "sm": {
          "$type": "dimension",
          "$value": "{foundation.spacing.1-5}"
        },
        "md": {
          "$type": "dimension",
          "$value": "{foundation.spacing.2}"
        },
        "lg": {
          "$type": "dimension",
          "$value": "{foundation.spacing.2-5}"
        }
      },
      "border-width": {
        "$type": "dimension",
        "$value": "{semantic.border.width.default}"
      },
      "border-radius-full": {
        "$type": "dimension",
        "$value": "{foundation.radius.full}",
        "$description": "Circle shape"
      },
      "label-border-radius": {
        "$type": "dimension",
        "$value": "{foundation.radius.sm}",
        "$description": "4px on label wrapper"
      },
      "gap": {
        "$type": "dimension",
        "$value": "{semantic.space.gap.sm}",
        "$description": "8px between control and label"
      },
      "group-gap": {
        "$type": "dimension",
        "$value": "{semantic.space.gap.xs}",
        "$description": "4px between radios in a group"
      },
      "group-legend-margin-bottom": {
        "$type": "dimension",
        "$value": "{semantic.space.gap.sm}",
        "$description": "8px below legend"
      },
      "group-margin-bottom": {
        "$type": "dimension",
        "$value": "{semantic.space.inset.lg}",
        "$description": "16px below radio group"
      },
      "label-padding-y": {
        "$type": "dimension",
        "$value": "0.375rem",
        "$description": "6px vertical padding on label wrapper (spacing-1-5 legacy)"
      },
      "label-padding-x": {
        "$type": "dimension",
        "$value": "{semantic.space.gap.xs}",
        "$description": "4px horizontal padding on label wrapper"
      },
      "content-gap": {
        "$type": "dimension",
        "$value": "{semantic.space.gap.xs}",
        "$description": "4px between label, description, helper"
      },
      "error-margin-top": {
        "$type": "dimension",
        "$value": "{semantic.space.gap.xs}",
        "$description": "4px above error message"
      },
      "min-target-size": {
        "$type": "dimension",
        "$value": "{semantic.size.control.min-target}",
        "$description": "44px — WCAG 2.5.5"
      },
      "font-size": {
        "$type": "dimension",
        "$value": "{foundation.typography.font.size.sm}",
        "$description": "14px label"
      },
      "legend-font-size": {
        "$type": "dimension",
        "$value": "{semantic.typography.body.font-size.sm}"
      },
      "legend-font-weight": {
        "$type": "number",
        "$value": "{semantic.typography.body.font-weight.medium}"
      },
      "label-font-size": {
        "$type": "dimension",
        "$value": "{semantic.typography.body.font-size.sm}"
      },
      "label-font-weight": {
        "$type": "number",
        "$value": "{semantic.typography.body.font-weight.medium}"
      },
      "label-line-height": {
        "$type": "number",
        "$value": "{semantic.typography.body.line-height.sm}"
      },
      "description-font-size": {
        "$type": "dimension",
        "$value": "{semantic.typography.body.font-size.sm}"
      },
      "description-font-weight": {
        "$type": "number",
        "$value": "{semantic.typography.body.font-weight.regular}"
      },
      "description-line-height": {
        "$type": "number",
        "$value": "{semantic.typography.body.line-height.md}"
      },
      "helper-font-size": {
        "$type": "dimension",
        "$value": "{semantic.typography.body.font-size.xs}"
      },
      "helper-line-height": {
        "$type": "number",
        "$value": "{semantic.typography.body.line-height.md}"
      },
      "error-font-size": {
        "$type": "dimension",
        "$value": "{semantic.typography.body.font-size.xs}"
      },
      "opacity-disabled": {
        "$type": "number",
        "$value": "{foundation.opacity.50}"
      },
      "transition-duration": {
        "$type": "duration",
        "$value": "{foundation.duration.fast}"
      },
      "transition-timing": {
        "$type": "cubicBezier",
        "$value": "{foundation.ease.default}"
      }
    }
  }
}
