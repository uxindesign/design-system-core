          "$description": "16px"
        },
        "md": {
          "$type": "dimension",
          "$value": "{foundation.spacing.5}",
          "$description": "20px"
        },
        "lg": {
          "$type": "dimension",
          "$value": "{foundation.spacing.6}",
          "$description": "24px"
        }
      },
      "dot-size": {
