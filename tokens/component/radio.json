{
  "component": {
    "radio": {
      "$description": "Dimensões do Radio por tamanho.",
      "control-size": {
        "sm": { "$type": "dimension", "$value": "{foundation.spacing.4}", "$description": "16px" },
        "md": { "$type": "dimension", "$value": "{foundation.spacing.5}", "$description": "20px" },
        "lg": { "$type": "dimension", "$value": "{foundation.spacing.6}", "$description": "24px" }
      },
      "dot-size": {
        "sm": { "$type": "dimension", "$value": "{foundation.spacing.1-5}", "$description": "6px" },
        "md": { "$type": "dimension", "$value": "{foundation.spacing.2}",   "$description": "8px" },
        "lg": { "$type": "dimension", "$value": "{foundation.spacing.2-5}", "$description": "10px" }
      }
    }
  }
}
