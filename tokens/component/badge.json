{
  "component": {
    "badge": {
      "root": {
        "padding-x": {
          "default": {
            "$type": "dimension",
            "$value": "{semantic.space.sm}",
            "$description": "Padding horizontal do root Badge."
          }
        },
        "padding-y": {
          "default": {
            "$type": "dimension",
            "$value": "{semantic.space.2xs}",
            "$description": "Padding vertical do root Badge."
          }
        },
        "gap": {
          "default": {
            "$type": "dimension",
            "$value": "{semantic.space.xs}",
            "$description": "Gap interno do root Badge."
          }
        },
        "radius": {
          "default": {
            "$type": "dimension",
            "$value": "{semantic.radius.full}",
            "$description": "Radius pill do root Badge."
          }
        },
        "border-width": {
          "default": {
            "$type": "dimension",
            "$value": "{semantic.border.width.default}",
            "$description": "Border width do root Badge quando stroke esta ativo."
          }
        }
      },
      "label": {
        "font-size": {
          "default": {
            "$type": "dimension",
            "$value": "{semantic.typography.body.font-size.xs}",
            "$description": "Font-size do label Badge."
          }
        },
        "line-height": {
          "default": {
            "$type": "dimension",
            "$value": "{semantic.typography.body.line-height.xs}",
            "$description": "Line-height do label Badge."
          }
        },
        "font-weight": {
          "default": {
            "$type": "number",
            "$value": "{semantic.typography.body.font-weight.bold}",
            "$description": "Font-weight do label Badge."
          }
        }
      }
    }
  }
}
