{
  "component": {
    "tooltip": {
      "$description": "Structural tokens for Tooltip component.",
      "padding-y": { "$type": "dimension", "$value": "{semantic.space.gap.xs}", "$description": "4px vertical padding" },
      "padding-x": { "$type": "dimension", "$value": "{semantic.space.gap.sm}", "$description": "8px horizontal padding" },
      "border-radius": { "$type": "dimension", "$value": "{foundation.radius.sm}", "$description": "4px" },
      "font-size": { "$type": "dimension", "$value": "{semantic.typography.body.font-size.xs}", "$description": "12px" },
      "z-index": { "$type": "number", "$value": "{foundation.z.50}" },
      "transition-duration": { "$type": "duration", "$value": "{foundation.duration.fast}" },
      "transition-timing": { "$type": "cubicBezier", "$value": "{foundation.ease.default}" }
    }
  }
}
