{
  "component": {
    "alert": {
      "padding": {
        "default": {
          "$type": "dimension",
          "$value": "{semantic.space.md}",
          "$description": "Padding do Alert."
        }
      },
      "gap": {
        "default": {
          "$type": "dimension",
          "$value": "{semantic.space.sm}",
          "$description": "Gap horizontal do Alert."
        }
      },
      "radius": {
        "default": {
          "$type": "dimension",
          "$value": "{semantic.radius.lg}",
          "$description": "Radius do Alert."
        }
      },
      "border-width": {
        "default": {
          "$type": "dimension",
          "$value": "{semantic.border.width.default}",
          "$description": "Border width do Alert quando stroke esta ativo."
        }
      },
      "icon": {
        "frame-size": {
          "default": {
            "$type": "dimension",
            "$value": "{semantic.size.md}",
            "$description": "Tamanho do frame do ícone Alert."
          }
        },
        "size": {
          "default": {
            "$type": "dimension",
            "$value": "{semantic.size.sm}",
            "$description": "Tamanho do ícone Alert."
          }
        }
      },
      "content": {
        "gap": {
          "default": {
            "$type": "dimension",
            "$value": "{semantic.space.xs}",
            "$description": "Gap vertical do content Alert."
          }
        }
      },
      "title": {
        "font-size": {
          "default": {
            "$type": "dimension",
            "$value": "{semantic.typography.body.font-size.sm}",
            "$description": "Font-size do title Alert."
          }
        },
        "line-height": {
          "default": {
            "$type": "dimension",
            "$value": "{semantic.typography.body.line-height.sm}",
            "$description": "Line-height do title Alert."
          }
        },
        "font-weight": {
          "default": {
            "$type": "number",
            "$value": "{semantic.typography.body.font-weight.bold}",
            "$description": "Font-weight do title Alert."
          }
        }
      },
      "description": {
        "font-size": {
          "default": {
            "$type": "dimension",
            "$value": "{semantic.typography.body.font-size.sm}",
            "$description": "Font-size da description Alert."
          }
        },
        "line-height": {
          "default": {
            "$type": "dimension",
            "$value": "{semantic.typography.body.line-height.sm}",
            "$description": "Line-height da description Alert."
          }
        },
        "font-weight": {
          "default": {
            "$type": "number",
            "$value": "{semantic.typography.body.font-weight.regular}",
            "$description": "Font-weight da description Alert."
          }
        }
      },
      "close": {
        "frame-size": {
          "default": {
            "$type": "dimension",
            "$value": "{semantic.size.md}",
            "$description": "Tamanho do frame do botão Close Alert."
          }
        },
        "icon-size": {
          "default": {
            "$type": "dimension",
            "$value": "{semantic.size.sm}",
            "$description": "Tamanho do ícone Close Alert."
          }
        }
      }
    }
  }
}
