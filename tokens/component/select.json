{
  "component": {
    "select": {
      "$description": "Dimensões do Select por tamanho.",
      "height": {
        "sm": { "$type": "dimension", "$value": "{semantic.size.control.sm}", "$description": "32px" },
        "md": { "$type": "dimension", "$value": "{semantic.size.control.md}", "$description": "40px" },
        "lg": { "$type": "dimension", "$value": "{semantic.size.control.lg}", "$description": "48px" }
      },
      "arrow-size": { "$type": "dimension", "$value": "{foundation.spacing.4}", "$description": "16px" },
      "arrow-offset": {
        "sm": { "$type": "dimension", "$value": "{foundation.spacing.2}", "$description": "8px" },
        "md": { "$type": "dimension", "$value": "{foundation.spacing.3}", "$description": "12px" },
        "lg": { "$type": "dimension", "$value": "{foundation.spacing.4}", "$description": "16px" }
      }
    }
  }
}
