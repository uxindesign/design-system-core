{
  "component": {
    "checkbox": {
      "$description": "Dimensões do Checkbox por tamanho.",
      "control-size": {
        "sm": { "$type": "dimension", "$value": "{foundation.spacing.4}", "$description": "16px" },
        "md": { "$type": "dimension", "$value": "{foundation.spacing.5}", "$description": "20px" },
        "lg": { "$type": "dimension", "$value": "{foundation.spacing.6}", "$description": "24px" }
      },
      "check-width": {
        "sm": { "$type": "dimension", "$value": "{foundation.spacing.1}",   "$description": "4px" },
        "md": { "$type": "dimension", "$value": "0.3125rem",                 "$description": "5px — valor fora da escala foundation" },
        "lg": { "$type": "dimension", "$value": "{foundation.spacing.1-5}", "$description": "6px" }
      },
      "check-height": {
        "sm": { "$type": "dimension", "$value": "{foundation.spacing.2}",   "$description": "8px" },
        "md": { "$type": "dimension", "$value": "{foundation.spacing.2-5}", "$description": "10px" },
        "lg": { "$type": "dimension", "$value": "{foundation.spacing.3}",   "$description": "12px" }
      }
    }
  }
}
