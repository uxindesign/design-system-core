{
  "component": {
    "textarea": {
      "$description": "Altura mínima do Textarea por tamanho. Valores específicos fora da escala de spacing (exceção ADR-013).",
      "min-height": {
        "sm": { "$type": "dimension", "$value": "4.25rem",                  "$description": "68px" },
        "md": { "$type": "dimension", "$value": "{foundation.spacing.20}",  "$description": "80px" },
        "lg": { "$type": "dimension", "$value": "7rem",                     "$description": "112px" }
      }
    }
  }
}
