{
  "component": {
    "modal": {
      "$description": "Structural tokens for Modal/Dialog component.",
      "max-width": {
        "sm": { "$type": "dimension", "$value": "25rem", "$description": "400px" },
        "md": { "$type": "dimension", "$value": "32.5rem", "$description": "520px" },
        "lg": { "$type": "dimension", "$value": "40rem", "$description": "640px" }
      },
      "padding": { "$type": "dimension", "$value": "{semantic.space.inset.lg}", "$description": "16px" },
      "border-radius": { "$type": "dimension", "$value": "1rem", "$description": "16px — xl radius for modal overlay" },
      "header-gap": { "$type": "dimension", "$value": "{semantic.space.gap.sm}", "$description": "8px between title and close" }
    }
  }
}
