{
  "component": {
    "toggle": {
      "$description": "Structural tokens for Toggle/Switch component.",
      "track-width": {
        "sm": {
          "$type": "dimension",
          "$value": "{foundation.spacing.7}",
          "$description": "28px"
        },
        "md": {
          "$type": "dimension",
          "$value": "{foundation.spacing.9}",
          "$description": "36px"
        },
        "lg": {
          "$type": "dimension",
          "$value": "{foundation.spacing.11}",
          "$description": "44px"
        }
      },
      "track-height": {
        "sm": {
          "$type": "dimension",
          "$value": "{foundation.spacing.4}",
          "$description": "16px"
        },
        "md": {
          "$type": "dimension",
          "$value": "{foundation.spacing.5}",
          "$description": "20px"
        },
        "lg": {
          "$type": "dimension",
          "$value": "{foundation.spacing.6}",
          "$description": "24px"
        }
      },
      "thumb-size": {
        "sm": {
          "$type": "dimension",
          "$value": "{foundation.spacing.2-5}",
          "$description": "10px"
        },
        "md": {
          "$type": "dimension",
          "$value": "{foundation.spacing.3-5}",
          "$description": "14px"
        },
        "lg": {
          "$type": "dimension",
          "$value": "1.125rem",
          "$description": "18px"
        }
      },
      "border-width": {
        "$type": "dimension",
        "$value": "{semantic.border.width.default}"
      },
      "border-radius-full": {
        "$type": "dimension",
        "$value": "{foundation.radius.full}",
        "$description": "Pill shape for track and thumb"
      },
      "label-border-radius": {
        "$type": "dimension",
        "$value": "{foundation.radius.sm}",
        "$description": "4px on label wrapper"
      },
      "gap": {
        "$type": "dimension",
        "$value": "{semantic.space.gap.sm}",
        "$description": "8px between toggle and label"
      },
      "label-padding-y": {
        "$type": "dimension",
        "$value": "0.375rem",
        "$description": "6px vertical padding on label wrapper (spacing-1-5 legacy)"
      },
      "label-padding-x": {
        "$type": "dimension",
        "$value": "{semantic.space.gap.xs}",
        "$description": "4px horizontal padding on label wrapper"
      },
      "content-gap": {
        "$type": "dimension",
        "$value": "{semantic.space.gap.xs}",
        "$description": "4px between label, description, helper"
      },
      "min-target-size": {
        "$type": "dimension",
        "$value": "{semantic.size.control.min-target}",
        "$description": "44px — WCAG 2.5.5"
      },
      "font-size": {
        "$type": "dimension",
        "$value": "{foundation.typography.font.size.sm}",
        "$description": "14px label"
      },
      "label-font-size": {
        "$type": "dimension",
        "$value": "{semantic.typography.body.font-size.sm}"
      },
      "label-font-weight": {
        "$type": "number",
        "$value": "{semantic.typography.body.font-weight.medium}"
      },
      "label-line-height": {
        "$type": "number",
        "$value": "{semantic.typography.body.line-height.sm}"
      },
      "description-font-size": {
        "$type": "dimension",
        "$value": "{semantic.typography.body.font-size.sm}"
      },
      "description-font-weight": {
        "$type": "number",
        "$value": "{semantic.typography.body.font-weight.regular}"
      },
      "description-line-height": {
        "$type": "number",
        "$value": "{semantic.typography.body.line-height.md}"
      },
      "helper-font-size": {
        "$type": "dimension",
        "$value": "{semantic.typography.body.font-size.xs}"
      },
      "helper-line-height": {
        "$type": "number",
        "$value": "{semantic.typography.body.line-height.md}"
      },
      "opacity-disabled": {
        "$type": "number",
        "$value": "{foundation.opacity.50}"
      },
      "transition-duration": {
        "$type": "duration",
        "$value": "{foundation.duration.fast}"
      },
      "transition-timing": {
        "$type": "cubicBezier",
        "$value": "{foundation.ease.default}"
      }
    }
  }
}
