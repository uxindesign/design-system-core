{
  "component": {
    "toggle": {
      "$description": "Dimensões do Toggle (switch) por tamanho.",
      "track-width": {
        "sm": { "$type": "dimension", "$value": "{foundation.spacing.7}",  "$description": "28px" },
        "md": { "$type": "dimension", "$value": "{foundation.spacing.9}",  "$description": "36px" },
        "lg": { "$type": "dimension", "$value": "{foundation.spacing.11}", "$description": "44px" }
      },
      "track-height": {
        "sm": { "$type": "dimension", "$value": "{foundation.spacing.4}", "$description": "16px" },
        "md": { "$type": "dimension", "$value": "{foundation.spacing.5}", "$description": "20px" },
        "lg": { "$type": "dimension", "$value": "{foundation.spacing.6}", "$description": "24px" }
      },
      "thumb-size": {
        "sm": { "$type": "dimension", "$value": "{foundation.spacing.2-5}", "$description": "10px" },
        "md": { "$type": "dimension", "$value": "{foundation.spacing.3-5}", "$description": "14px" },
        "lg": { "$type": "dimension", "$value": "1.125rem",                  "$description": "18px — fora da escala foundation" }
      }
    }
  }
}
