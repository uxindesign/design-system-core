{
  "component": {
    "input": {
      "$description": "Structural tokens for Input component. Same sizing system as Button (32/40/48).",
      "height": {
        "sm": { "$type": "dimension", "$value": "2rem", "$description": "32px" },
        "md": { "$type": "dimension", "$value": "2.5rem", "$description": "40px" },
        "lg": { "$type": "dimension", "$value": "3rem", "$description": "48px" }
      },
      "padding": {
        "sm": { "$type": "dimension", "$value": "{semantic.space.inset.md}", "$description": "12px" },
        "md": { "$type": "dimension", "$value": "{semantic.space.inset.lg}", "$description": "16px" },
        "lg": { "$type": "dimension", "$value": "{semantic.space.component.xl}", "$description": "20px" }
      },
      "gap": { "$type": "dimension", "$value": "{semantic.space.gap.sm}", "$description": "8px gap between icon and field" },
      "border-radius": { "$type": "dimension", "$value": "{semantic.radius.component}" },
      "border-width": { "$type": "dimension", "$value": "{semantic.border.width.default}" },
      "font-size": {
        "sm": { "$type": "dimension", "$value": "0.875rem", "$description": "14px" },
        "md": { "$type": "dimension", "$value": "0.875rem", "$description": "14px" },
        "lg": { "$type": "dimension", "$value": "1rem", "$description": "16px" }
      },
      "icon-size": {
        "sm": { "$type": "dimension", "$value": "1rem", "$description": "16px" },
        "md": { "$type": "dimension", "$value": "1.25rem", "$description": "20px" },
        "lg": { "$type": "dimension", "$value": "1.5rem", "$description": "24px" }
      }
    }
  }
}
