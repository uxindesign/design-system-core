{
  "component": {
    "spinner": {
      "$description": "Dimensões do Spinner por tamanho.",
      "size": {
        "sm": { "$type": "dimension", "$value": "{foundation.spacing.4}", "$description": "16px" },
        "md": { "$type": "dimension", "$value": "{foundation.spacing.6}", "$description": "24px" },
        "lg": { "$type": "dimension", "$value": "{foundation.spacing.8}", "$description": "32px" }
      },
      "stroke-width": {
        "sm": { "$type": "dimension", "$value": "0.09375rem", "$description": "1.5px — fora da escala foundation" },
        "md": { "$type": "dimension", "$value": "{foundation.border.width.2}", "$description": "2px" },
        "lg": { "$type": "dimension", "$value": "0.1875rem",  "$description": "3px — fora da escala foundation" }
      }
    }
  }
}
