{
  "component": {
    "button": {
      "$description": "Structural tokens for the Button component. Heights, padding, font-size, and icon-size reference semantic control tokens (ADR-006). Color tokens are consumed directly from semantic (color.primary.*, feedback.*) — see CSS.",
      "height": {
        "sm": {
          "$type": "dimension",
          "$value": "{semantic.size.control.sm}",
          "$description": "32px"
        },
        "md": {
          "$type": "dimension",
          "$value": "{semantic.size.control.md}",
          "$description": "40px"
        },
        "lg": {
          "$type": "dimension",
          "$value": "{semantic.size.control.lg}",
          "$description": "48px"
        }
      },
      "padding-x": {
        "sm": {
          "$type": "dimension",
          "$value": "{semantic.space.control.padding-x.sm}",
          "$description": "12px horizontal padding"
        },
        "md": {
          "$type": "dimension",
          "$value": "{semantic.space.control.padding-x.md}",
          "$description": "16px horizontal padding"
        },
        "lg": {
          "$type": "dimension",
          "$value": "{semantic.space.control.padding-x.lg}",
          "$description": "20px horizontal padding"
        }
      },
      "padding-y": {
        "sm": {
          "$type": "dimension",
          "$value": "{semantic.space.control.padding-y.sm}",
          "$description": "8px vertical padding"
        },
        "md": {
          "$type": "dimension",
          "$value": "{semantic.space.control.padding-y.md}",
          "$description": "10px vertical padding"
        },
        "lg": {
          "$type": "dimension",
          "$value": "{semantic.space.control.padding-y.lg}",
          "$description": "12px vertical padding"
        }
      },
      "gap": {
        "$type": "dimension",
        "$value": "{semantic.space.gap.sm}",
        "$description": "8px gap between icon and label"
      },
      "border-radius": {
        "$type": "dimension",
        "$value": "{semantic.radius.component}"
      },
      "border-width": {
        "$type": "dimension",
        "$value": "{semantic.border.width.default}"
      },
      "font-size": {
        "sm": {
          "$type": "dimension",
          "$value": "{semantic.typography.control.font-size.sm}",
          "$description": "0.875rem (14px)"
        },
        "md": {
          "$type": "dimension",
          "$value": "{semantic.typography.control.font-size.md}",
          "$description": "0.875rem (14px)"
        },
        "lg": {
          "$type": "dimension",
          "$value": "{semantic.typography.control.font-size.lg}",
          "$description": "1rem (16px)"
        }
      },
      "icon-size": {
        "sm": {
          "$type": "dimension",
          "$value": "{semantic.size.control.icon.sm}",
          "$description": "16px"
        },
        "md": {
          "$type": "dimension",
          "$value": "{semantic.size.control.icon.md}",
          "$description": "20px"
        },
        "lg": {
          "$type": "dimension",
          "$value": "{semantic.size.control.icon.lg}",
          "$description": "24px"
        }
      },
      "min-target-size": {
        "$type": "dimension",
        "$value": "{semantic.size.control.min-target}",
        "$description": "44px — WCAG 2.5.5 enhanced touch target"
      },
      "background": {
        "toned": {
          "default": {
            "$type": "color",
            "$value": "{semantic.color.primary.toned.default}",
            "$description": "Toned variant background. ADR-007."
          },
          "hover": {
            "$type": "color",
            "$value": "{semantic.color.primary.toned.hover}"
          },
          "active": {
            "$type": "color",
            "$value": "{semantic.color.primary.toned.active}"
          },
          "disabled": {
            "$type": "color",
            "$value": "{semantic.state.disabled.background}",
            "$description": "Opaque neutral — toned transparency not needed for disabled."
          }
        }
      },
      "foreground": {
        "toned": {
          "default": {
            "$type": "color",
            "$value": "{semantic.color.primary.text}",
            "$description": "Text/icon color on toned background."
          },
          "disabled": {
            "$type": "color",
            "$value": "{semantic.state.disabled.foreground}"
          }
        }
      }
    }
  }
}
