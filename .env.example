# Variáveis de ambiente necessárias para os scripts de build/sync.
# Copie este arquivo para .env e preencha os valores.
# .env está no .gitignore — nunca commitar credenciais.

# File key do arquivo Figma que contém as Variables do design system.
# Encontrado na URL do Figma: figma.com/design/<FIGMA_FILE_KEY>/...
FIGMA_FILE_KEY=

# Personal Access Token do Figma com permissão de leitura de Variables.
# Gerado em: Figma → Account Settings → Personal access tokens.
FIGMA_PAT=
